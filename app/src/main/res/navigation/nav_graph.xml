<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.aman.browser.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_browser"
            app:destination="@id/browserFragment" />
    </fragment>

    <fragment
        android:id="@+id/browserFragment"
        android:name="com.aman.browser.browser.BrowserFragment"
        android:label="Browser"
        tools:layout="@layout/fragment_browser">
        <argument
            android:name="url"
            app:argType="string"
            android:defaultValue="https://www.google.com" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.aman.browser.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/appsFragment"
        android:name="com.aman.browser.ui.apps.AppsFragment"
        android:label="Apps" />

    <fragment
        android:id="@+id/statsFragment"
        android:name="com.aman.browser.ui.stats.StatsFragment"
        android:label="Stats"
        tools:layout="@layout/fragment_stats" />

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.aman.browser.ui.onboarding.OnboardingFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_onboarding" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.aman.browser.ui.history.HistoryFragment"
        android:label="History" />

    <fragment
        android:id="@+id/downloadsFragment"
        android:name="com.aman.browser.ui.downloads.DownloadsFragment"
        android:label="Downloads" />

</navigation>
